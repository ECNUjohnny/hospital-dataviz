# ====================================================
# 1. 依赖文件夹 (绝对不能提交！)
# ====================================================
node_modules/
.pnp
.pnp.js

# ====================================================
# 2. 生产环境构建输出目录 (不需要提交，每次打包都会重新生成)
# ====================================================
dist/
dist-ssr/
build/

# ====================================================
# 3. 本地环境变量 (极其重要：防止泄露 API Key 和密码)
# ====================================================
.env.local
.env.development.local
.env.test.local
.env.production.local

# ====================================================
# 4. 日志文件 (运行出错时产生的记录文件)
# ====================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ====================================================
# 5. 编辑器和 IDE 个人配置 (避免干扰其他协作者)
# ====================================================
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ====================================================
# 6. TypeScript 相关 (如果你用 TS 的话)
# ====================================================
tsbuildinfo